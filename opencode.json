{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "code-reviewer": {
      "description": "Reviews code for best practices and potential issues",
      "mode": "subagent",
      "prompt": "{file:./.opencode/agents/code-review.md}",
      "tools": {
        "write": false,
        "edit": false
      }
    },
    "unit-test-writer": {
      "description": "Writes high-quality unit tests with strong edge-case coverage",
      "mode": "subagent",
      "prompt": "{file:./.opencode/agents/unit-test-writer.md}",
      "tools": {
        "write": false,
        "edit": true,
        "bash": false
      }
    }
  }
}
