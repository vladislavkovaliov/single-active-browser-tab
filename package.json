{
  "name": "single-active-browser-tab",
  "version": "1.6.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "LOG_LEVEL=error jest",
    "test:coverage": "LOG_LEVEL=error jest --coverage",
    "dev": "VITE_LOG_LEVEL=error vite",
    "build": "rm -rf dist && tsup",
    "preview": "vite preview",
    "test:e2e": "start-server-and-test dev http://localhost:5173 cy:run",
    "test:pw": "playwright test",
    "test:pw:ui": "playwright test --ui",
    "playwright:install": "playwright install chromium",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "format:check": "prettier --check src/**/*.{ts,tsx}",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "postinstall": "playwright install chromium",
    "cz": "git-cz",
    "cm": "cz"
  },
  "files": [
    "dist",
    "types",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "require": "./dist/single-tab-manager.cjs",
      "import": "./dist/single-tab-manager.js"
    },
    "./sw.js": "./dist/assets/sw.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "npm run lint",
      "npm run prettier"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./cz-adapter"
    }
  },
  "keywords": [
    "browser",
    "tab",
    "browser-tab",
    "active-tab",
    "focus",
    "window",
    "extension"
  ],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "wi-console-logger": "^1.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^4.3.3",
    "commitizen": "^4.3.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "inquirer": "^13.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.0.8",
    "ts-jest": "^29.4.6",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^6.0.3"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": "24",
    "npm": "11"
  }
}
